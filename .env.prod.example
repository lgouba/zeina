# =============================================================================
# ZEINA — variables d'environnement de production (qalitylabs.fr)
# Copier vers .env.prod et REMPLIR LES SECRETS. Ne jamais commiter .env.prod.
# =============================================================================

# --- PostgreSQL / TimescaleDB -------------------------------------------------
POSTGRES_USER=zeina
POSTGRES_PASSWORD=__CHANGE_ME__strong_random_pg_password
POSTGRES_DB=zeina

# --- Mosquitto MQTT -----------------------------------------------------------
MQTT_API_USER=api
MQTT_API_PASSWORD=__CHANGE_ME__mqtt_api
MQTT_INGESTOR_USER=ingestor
MQTT_INGESTOR_PASSWORD=__CHANGE_ME__mqtt_ingestor
MQTT_RULES_USER=rules
MQTT_RULES_PASSWORD=__CHANGE_ME__mqtt_rules
MQTT_SIMULATOR_USER=simulator
MQTT_SIMULATOR_PASSWORD=__CHANGE_ME__mqtt_sim

# --- API ----------------------------------------------------------------------
# JWT_SECRET : générer avec `openssl rand -base64 48`
JWT_SECRET=__CHANGE_ME__at_least_32_chars_random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Origines autorisées par CORS — la SPA tape sur des chemins relatifs donc
# en pratique pas de cross-origin, mais on liste les domaines publics au cas
# où un dev appelle directement api-zeina depuis Bruno/Swagger.
CORS_ALLOWED_ORIGINS=https://zeina.qalitylabs.fr,https://api-zeina.qalitylabs.fr

RATE_LIMIT_RPS=20
DEMO_TENANT_SLUG=acme

# --- Reverse proxy nginx-proxy / acme-companion -------------------------------
# Domaines publics auto-détectés par jwilder/nginx-proxy + LE auto-issued.
FRONTEND_DOMAIN=zeina.qalitylabs.fr
API_DOMAIN=api-zeina.qalitylabs.fr
# Email pour les certificats Let's Encrypt
LETSENCRYPT_EMAIL=hakeemgouba@gmail.com

# --- Logger -------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
