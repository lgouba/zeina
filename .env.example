# =============================================================================
# ZEINA — variables d'environnement (copier vers .env et adapter)
# =============================================================================

# --- PostgreSQL / TimescaleDB -------------------------------------------------
POSTGRES_USER=zeina
POSTGRES_PASSWORD=changeme_pg
POSTGRES_DB=zeina
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
DATABASE_URL=postgres://zeina:changeme_pg@timescaledb:5432/zeina?sslmode=disable

# --- Mosquitto MQTT -----------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
# Utilisateurs applicatifs (créés par scripts/mosquitto-bootstrap.sh)
MQTT_API_USER=api
MQTT_API_PASSWORD=changeme_api
MQTT_INGESTOR_USER=ingestor
MQTT_INGESTOR_PASSWORD=changeme_ingestor
MQTT_RULES_USER=rules
MQTT_RULES_PASSWORD=changeme_rules
MQTT_SIMULATOR_USER=simulator
MQTT_SIMULATOR_PASSWORD=changeme_sim

# --- Redis --------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- API ----------------------------------------------------------------------
API_PORT=3000           # port interne du conteneur (mappé sur 3030 côté host)
API_BIND=0.0.0.0
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3030
RATE_LIMIT_RPS=20

# --- Ingestor -----------------------------------------------------------------
INGESTOR_METRICS_PORT=9090
INGESTOR_BATCH_SIZE=500
INGESTOR_BATCH_TIMEOUT=1s
INGESTOR_CHANNEL_BUFFER=10000

# --- Rules engine -------------------------------------------------------------
RULES_METRICS_PORT=9091

# --- Simulator ----------------------------------------------------------------
SIMULATOR_CONFIG=/etc/simulator/simulator.yml
SIMULATOR_SEED=42

# --- Logger -------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# --- Frontend (build-time) ----------------------------------------------------
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/v1/ws
